# Adminpanel (Next.js) PRODUCTION runtime env.
# Copy to /opt/onfood-prod/env/adminpanel.prod.env; never commit real values.

NODE_ENV=production

# Database - password must match /opt/onfood-prod/.env.
DATABASE_URL=postgresql://onfood:REPLACE_POSTGRES_PASSWORD@postgres:5432/onfood_prod?sslmode=disable

ADMIN_TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_IDS=
ADMIN_TELEGRAM_WEBHOOK_URL=https://admin.onfood.uz/api/telegram/webhook
ADMIN_TELEGRAM_WEBHOOK_SECRET=

ADMIN_SESSION_SECRET=

# Service-only story moderation. Secret must exactly match backend.prod.env.
STORY_MODERATION_INTERNAL_URL=http://eats-api:8001
STORY_MODERATION_INTERNAL_SECRET=REPLACE_WITH_SHARED_64_HEX_SECRET

R2_ACCESS_KEY_ID=REPLACE_MINIO_ROOT_USER
R2_SECRET_ACCESS_KEY=REPLACE_MINIO_ROOT_PASSWORD
R2_BUCKET=onfood-images
R2_ENDPOINT=https://cdn.onfood.uz
R2_PUBLIC_URL=https://cdn.onfood.uz/onfood-images
R2_ACCOUNT_ID=

ERROR_TELEGRAM_IDS=
YANDEX_GEOCODER_API_KEY=
