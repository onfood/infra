# Adminpanel (Next.js) TEST runtime env — copy to /opt/onfood-dev/env/adminpanel.env.
# Adminpanel talks to postgres directly via Drizzle (no Go backend in the path).
#
# ⚠️ NODE_ENV=production makes the env validator REQUIRED at boot — these MUST be
# non-empty or the container crash-loops: ADMIN_TELEGRAM_BOT_TOKEN, ADMIN_TELEGRAM_IDS,
# ERROR_TELEGRAM_IDS, ADMIN_TELEGRAM_WEBHOOK_SECRET, ADMIN_SESSION_SECRET.
# Note: the startup instrumentation hook calls Telegram getWebhookInfo/sendMessage,
# so ADMIN_TELEGRAM_BOT_TOKEN must be a REAL valid token (a fake string boots the
# env validator but then 401s and crashes the server).

NODE_ENV=production

# Database — must match POSTGRES_* in /opt/onfood-dev/.env
DATABASE_URL=postgresql://onfood:REPLACE_POSTGRES_PASSWORD@postgres:5432/onfood_db_dev?sslmode=disable

# Telegram bot for admin sign-in (TEST bot — never reuse prod). REQUIRED, must be valid.
ADMIN_TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_IDS=1                             # REQUIRED — comma-separated admin Telegram IDs (replace 1 with your real ID to log in)

# Webhook (admin bot listens on a Next.js API route on the admin domain)
ADMIN_TELEGRAM_WEBHOOK_URL=https://test-admin.onfood.uz/api/telegram/webhook
ADMIN_TELEGRAM_WEBHOOK_SECRET=                   # openssl rand -hex 32

# Auth
ADMIN_SESSION_SECRET=                            # openssl rand -hex 64

# Image upload (MinIO via test-cdn.onfood.uz)
R2_ACCESS_KEY_ID=REPLACE_MINIO_ROOT_USER
R2_SECRET_ACCESS_KEY=REPLACE_MINIO_ROOT_PASSWORD
R2_BUCKET=onfood-images
R2_ENDPOINT=https://test-cdn.onfood.uz
R2_PUBLIC_URL=https://test-cdn.onfood.uz/onfood-images
R2_ACCOUNT_ID=

# Error notifications — REQUIRED non-empty when NODE_ENV=production
ERROR_TELEGRAM_IDS=1

# Server-side Yandex geocoder (address lookup). Optional.
YANDEX_GEOCODER_API_KEY=5f7c9b43-c808-4497-a77d-6600af8097ab
