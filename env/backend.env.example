# Backend (Go) TEST env — copy to /opt/onfood-dev/env/backend.env on the server.
# Loaded by eats-api, business-api, eats-bot, business-bot, scheduler.
# URLs reflect the centralized test-api gateway (test-api.onfood.uz/eats|/business).

ENV=dev
LOG_LEVEL=debug

# Database — must match POSTGRES_* in /opt/onfood-dev/.env
DATABASE_URL=postgresql://onfood:REPLACE_POSTGRES_PASSWORD@postgres:5432/onfood_db_dev?sslmode=disable

# ── Eats side ─────────────────────────────────────────────────────────
EATS_BOT_TOKEN=                                   # TEST bot from @BotFather (never reuse prod)
EATS_OIDC_CLIENT_ID=
EATS_OIDC_CLIENT_SECRET=
EATS_OIDC_REDIRECT_URL=https://test-api.onfood.uz/eats/api/v1/auth/oidc/callback
EATS_API_PORT=8001
EATS_APP_URL=https://test-eats.onfood.uz
EATS_MINIAPP_URL=https://test-eats.onfood.uz
EATS_WEBHOOK_URL=https://test-api.onfood.uz/webhooks/eats
EATS_WEBHOOK_SECRET=                              # openssl rand -hex 32
EATS_CORS_ALLOWED_ORIGINS=https://test-eats.onfood.uz

# ── Business side ─────────────────────────────────────────────────────
BUSINESS_BOT_TOKEN=                               # TEST bot from @BotFather
BUSINESS_OIDC_CLIENT_ID=
BUSINESS_OIDC_CLIENT_SECRET=
BUSINESS_OIDC_REDIRECT_URL=https://test-api.onfood.uz/business/api/v1/auth/oidc/callback
BUSINESS_API_PORT=8002
BUSINESS_APP_URL=https://test-business.onfood.uz
BUSINESS_MINIAPP_URL=https://test-business.onfood.uz
BUSINESS_WEBHOOK_URL=https://test-api.onfood.uz/webhooks/business
BUSINESS_WEBHOOK_SECRET=                          # openssl rand -hex 32
BUSINESS_CORS_ALLOWED_ORIGINS=https://test-business.onfood.uz

# ── Auth ──────────────────────────────────────────────────────────────
SESSION_SECRET=                                   # openssl rand -hex 64

# ── Image storage (MinIO via test-cdn.onfood.uz) ──────────────────────
# Endpoint must be browser-reachable: the backend signs presigned URLs for
# this host and the browser PUTs/GETs directly.
R2_ACCESS_KEY=REPLACE_MINIO_ROOT_USER
R2_SECRET_KEY=REPLACE_MINIO_ROOT_PASSWORD
R2_BUCKET=onfood-images
R2_ENDPOINT=https://test-cdn.onfood.uz
R2_PUBLIC_URL=https://test-cdn.onfood.uz/onfood-images
R2_ACCOUNT_ID=

# Story raw, staging, HLS staging, and moderation MP4. This bucket has no
# anonymous policy; the endpoint must still be browser-reachable for signed PUT.
STORY_PRIVATE_S3_ACCESS_KEY=REPLACE_MINIO_ROOT_USER
STORY_PRIVATE_S3_SECRET_KEY=REPLACE_MINIO_ROOT_PASSWORD
STORY_PRIVATE_S3_BUCKET=onfood-story-private
STORY_PRIVATE_S3_ENDPOINT=https://test-cdn.onfood.uz
STORY_PRIVATE_S3_ACCOUNT_ID=

# Approved poster/HLS generations only. This may share the public image bucket.
STORY_PUBLIC_S3_ACCESS_KEY=REPLACE_MINIO_ROOT_USER
STORY_PUBLIC_S3_SECRET_KEY=REPLACE_MINIO_ROOT_PASSWORD
STORY_PUBLIC_S3_BUCKET=onfood-images
STORY_PUBLIC_S3_ENDPOINT=https://test-cdn.onfood.uz
STORY_PUBLIC_S3_PUBLIC_URL=https://test-cdn.onfood.uz/onfood-images
STORY_PUBLIC_S3_ACCOUNT_ID=

# Shared only with adminpanel. Generate one value with: openssl rand -hex 32
STORY_MODERATION_INTERNAL_SECRET=REPLACE_WITH_SHARED_64_HEX_SECRET
STORY_MEDIA_MAX_RAW_SIZE_BYTES=104857600
STORY_MEDIA_MAX_DURATION=30s
STORY_MEDIA_FFMPEG_PATH=ffmpeg
STORY_MEDIA_FFPROBE_PATH=ffprobe
STORY_MEDIA_PROCESSOR_BATCH_SIZE=1
# Deprecated rollout alias, leave unset after switching to BATCH_SIZE:
# STORY_MEDIA_PROCESSOR_CONCURRENCY=1
STORY_MEDIA_TEMP_DIR=/tmp/onfood-media
STORY_MEDIA_PROCESSING_LEASE=15m
STORY_MEDIA_FINALIZE_TIMEOUT=10s
STORY_MEDIA_MAX_INPUT_WIDTH=4096
STORY_MEDIA_MAX_INPUT_HEIGHT=4096
STORY_MEDIA_MAX_INPUT_PIXELS=10000000
STORY_MEDIA_MAX_FRAME_RATE=60.1
STORY_MEDIA_FFMPEG_THREADS=2
STORY_MEDIA_COMMAND_TIMEOUT=5m
STORY_MEDIA_MAX_COMMAND_OUTPUT_BYTES=65536
STORY_PUBLICATION_BATCH_SIZE=5
STORY_PUBLICATION_LEASE=5m
STORY_PUBLICATION_FINALIZE_TIMEOUT=10s
STORY_MODERATION_BATCH_SIZE=10
STORY_CLEANUP_BATCH_SIZE=50

# Review still-image normalization: physically oriented sRGB(A), exact lossless WebP.
REVIEW_MEDIA_VIPS_PATH=vips
REVIEW_MEDIA_VIPSHEADER_PATH=vipsheader
REVIEW_MEDIA_CWEBP_PATH=cwebp
REVIEW_MEDIA_TEMP_DIR=/tmp/onfood-media
REVIEW_MEDIA_PROCESSOR_BATCH_SIZE=5
REVIEW_MEDIA_PROCESSING_LEASE=5m
REVIEW_MEDIA_FINALIZE_TIMEOUT=10s
REVIEW_MEDIA_MAX_SIDE=16384
REVIEW_MEDIA_MAX_PIXELS=64000000
REVIEW_MEDIA_MAX_INPUT_BYTES=10485760
REVIEW_MEDIA_MAX_OUTPUT_BYTES=268435456
REVIEW_MEDIA_MAX_COMMAND_OUTPUT_BYTES=65536
REVIEW_MEDIA_COMMAND_TIMEOUT=2m
REVIEW_MEDIA_CLEANUP_BATCH_SIZE=50
MEDIA_TEMP_MAX_AGE=1h
MEDIA_TEMP_CLEANUP_BATCH_SIZE=100

# Deprecated public story storage aliases are parsed only for rollout diagnostics.
# They never replace STORY_PRIVATE_S3_*:
# STORY_MEDIA_S3_ENDPOINT=
# STORY_MEDIA_S3_ACCESS_KEY=
# STORY_MEDIA_S3_SECRET_KEY=
# STORY_MEDIA_S3_BUCKET=

# ── Click payment provider (sandbox / disabled for test) ──────────────
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
CLICK_MERCHANT_USER_ID=
CLICK_RETURN_URL=https://test-eats.onfood.uz/orders

# ── App-level ─────────────────────────────────────────────────────────
APP_TIMEZONE=Asia/Tashkent

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Sentry (optional on test) ─────────────────────────────────────────
SENTRY_DSN=

# ── Error / feedback notifications (optional on test) ─────────────────
ERROR_TELEGRAM_IDS=
ERROR_BOT_TOKEN=
FEEDBACK_TELEGRAM_CHAT_IDS=
ADMIN_TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_IDS=
