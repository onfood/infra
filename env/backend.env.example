# Backend (Go) TEST env — copy to /opt/onfood-dev/env/backend.env on the server.
# Loaded by eats-api, business-api, eats-bot, business-bot, scheduler.
# URLs reflect the centralized test-api gateway (test-api.onfood.uz/eats|/business).

ENV=dev
LOG_LEVEL=debug

# Database — must match POSTGRES_* in /opt/onfood-dev/.env
DATABASE_URL=postgresql://onfood:REPLACE_POSTGRES_PASSWORD@postgres:5432/onfood_db_dev?sslmode=disable

# ── Eats side ─────────────────────────────────────────────────────────
EATS_BOT_TOKEN=                                   # TEST bot from @BotFather (never reuse prod)
EATS_OIDC_CLIENT_ID=
EATS_OIDC_CLIENT_SECRET=
EATS_OIDC_REDIRECT_URL=https://test-api.onfood.uz/eats/api/v1/auth/oidc/callback
EATS_API_PORT=8001
EATS_APP_URL=https://test-eats.onfood.uz
EATS_MINIAPP_URL=https://test-eats.onfood.uz
EATS_WEBHOOK_URL=https://test-api.onfood.uz/webhooks/eats
EATS_WEBHOOK_SECRET=                              # openssl rand -hex 32
EATS_CORS_ALLOWED_ORIGINS=https://test-eats.onfood.uz

# ── Business side ─────────────────────────────────────────────────────
BUSINESS_BOT_TOKEN=                               # TEST bot from @BotFather
BUSINESS_OIDC_CLIENT_ID=
BUSINESS_OIDC_CLIENT_SECRET=
BUSINESS_OIDC_REDIRECT_URL=https://test-api.onfood.uz/business/api/v1/auth/oidc/callback
BUSINESS_API_PORT=8002
BUSINESS_APP_URL=https://test-business.onfood.uz
BUSINESS_MINIAPP_URL=https://test-business.onfood.uz
BUSINESS_WEBHOOK_URL=https://test-api.onfood.uz/webhooks/business
BUSINESS_WEBHOOK_SECRET=                          # openssl rand -hex 32
BUSINESS_CORS_ALLOWED_ORIGINS=https://test-business.onfood.uz

# ── Auth ──────────────────────────────────────────────────────────────
SESSION_SECRET=                                   # openssl rand -hex 64

# ── Image storage (MinIO via test-cdn.onfood.uz) ──────────────────────
# Endpoint must be browser-reachable: the backend signs presigned URLs for
# this host and the browser PUTs/GETs directly.
R2_ACCESS_KEY=REPLACE_MINIO_ROOT_USER
R2_SECRET_KEY=REPLACE_MINIO_ROOT_PASSWORD
R2_BUCKET=onfood-images
R2_ENDPOINT=https://test-cdn.onfood.uz
R2_PUBLIC_URL=https://test-cdn.onfood.uz/onfood-images
R2_ACCOUNT_ID=

# ── Click payment provider (sandbox / disabled for test) ──────────────
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
CLICK_MERCHANT_USER_ID=
CLICK_RETURN_URL=https://test-eats.onfood.uz/orders

# ── App-level ─────────────────────────────────────────────────────────
APP_TIMEZONE=Asia/Tashkent

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Sentry (optional on test) ─────────────────────────────────────────
SENTRY_DSN=

# ── Error / feedback notifications (optional on test) ─────────────────
ERROR_TELEGRAM_IDS=
ERROR_BOT_TOKEN=
FEEDBACK_TELEGRAM_CHAT_IDS=
