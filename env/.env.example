# ─────────────────────────────────────────────────────────────────────
# Compose-level env for the onfood-dev stack.
# Copy to /opt/onfood-dev/.env on the server (gitignored), fill real values.
# Read by docker compose itself (substitutions), NOT loaded into containers.
# ─────────────────────────────────────────────────────────────────────

POSTGRES_USER=onfood
POSTGRES_PASSWORD=CHANGEME            # openssl rand -hex 32
POSTGRES_DB=onfood_db_dev

MINIO_ROOT_USER=onfood
MINIO_ROOT_PASSWORD=CHANGEME          # openssl rand -hex 32

# Bucket created by the minio-setup one-shot; must match R2_BUCKET in backend.env
R2_BUCKET=onfood-images
STORY_PRIVATE_S3_BUCKET=onfood-story-private
STORY_PUBLIC_S3_BUCKET=onfood-images
