# ─────────────────────────────────────────────────────────────────────
# Top-level secrets used by docker-compose (NOT per-service)
# Copy to .env (gitignored), fill values, on server only.
# ─────────────────────────────────────────────────────────────────────

POSTGRES_USER=qber
POSTGRES_PASSWORD=CHANGEME_strong_pw_here
POSTGRES_DB=qber

# ─────────────────────────────────────────────────────────────────────
# These per-service env files live in env/*.env on the server.
# Each service in docker-compose.yml uses `env_file:` to load its own.
# Example values shown — server has real ones, never commit those.
# ─────────────────────────────────────────────────────────────────────

# env/customer-api.env example:
# DATABASE_URL=postgres://qber:PASS@postgres:5432/qber?sslmode=disable
# SESSION_SECRET=...
# CUSTOMER_BOT_TOKEN=...
# CUSTOMER_OIDC_CLIENT_ID=...
# CUSTOMER_OIDC_CLIENT_SECRET=...
# PUBLIC_BASE_URL=https://eats.qber.uz
# CUSTOMER_API_PORT=8001
# CLICK_*=...

# env/customer.env example:
# BACKEND_URL=http://customer-api:8001
# NEXT_PUBLIC_TELEGRAM_OAUTH_CLIENT_ID=...
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=qber_eats_bot
# SESSION_COOKIE_NAME=onfood_session
