# Business (Next.js) TEST runtime env — copy to /opt/onfood-dev/env/business.env.
# Build-time NEXT_PUBLIC_* are baked into the image by CI (see workflow), not here.

NODE_ENV=production

# Server-side proxy to the Go API via the internal docker hostname.
BACKEND_URL=http://business-api:8002

# Server-side Yandex geocoder (address lookup). Optional — geocode endpoint
# returns 503 if unset.
YANDEX_GEOCODER_API_KEY=5f7c9b43-c808-4497-a77d-6600af8097ab
