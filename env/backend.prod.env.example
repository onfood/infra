# Backend (Go) PRODUCTION env.
# Copy to /opt/onfood-prod/env/backend.prod.env; never commit real values.

ENV=prod
LOG_LEVEL=info

# Database - password must match /opt/onfood-prod/.env.
DATABASE_URL=postgresql://onfood:REPLACE_POSTGRES_PASSWORD@postgres:5432/onfood_prod?sslmode=disable

# Eats side
EATS_BOT_TOKEN=
EATS_API_PORT=8001
EATS_APP_URL=https://eats.onfood.uz
EATS_MINIAPP_URL=https://eats.onfood.uz
EATS_WEBHOOK_URL=https://eats.onfood.uz/webhooks/eats
EATS_WEBHOOK_SECRET=
EATS_CORS_ALLOWED_ORIGINS=https://eats.onfood.uz

# Business side
BUSINESS_BOT_TOKEN=
BUSINESS_API_PORT=8002
BUSINESS_APP_URL=https://business.onfood.uz
BUSINESS_MINIAPP_URL=https://business.onfood.uz
BUSINESS_WEBHOOK_URL=https://business.onfood.uz/webhooks/business
BUSINESS_WEBHOOK_SECRET=
BUSINESS_CORS_ALLOWED_ORIGINS=https://business.onfood.uz

# Auth
SESSION_SECRET=

# Image and story storage - MinIO behind https://cdn.onfood.uz.
R2_ACCESS_KEY=REPLACE_MINIO_ROOT_USER
R2_SECRET_KEY=REPLACE_MINIO_ROOT_PASSWORD
R2_BUCKET=onfood-images
R2_ENDPOINT=https://cdn.onfood.uz
R2_PUBLIC_URL=https://cdn.onfood.uz/onfood-images
R2_ACCOUNT_ID=

STORY_PRIVATE_S3_ACCESS_KEY=REPLACE_MINIO_ROOT_USER
STORY_PRIVATE_S3_SECRET_KEY=REPLACE_MINIO_ROOT_PASSWORD
STORY_PRIVATE_S3_BUCKET=onfood-story-private
STORY_PRIVATE_S3_ENDPOINT=https://cdn.onfood.uz
STORY_PRIVATE_S3_ACCOUNT_ID=

STORY_PUBLIC_S3_ACCESS_KEY=REPLACE_MINIO_ROOT_USER
STORY_PUBLIC_S3_SECRET_KEY=REPLACE_MINIO_ROOT_PASSWORD
STORY_PUBLIC_S3_BUCKET=onfood-images
STORY_PUBLIC_S3_ENDPOINT=https://cdn.onfood.uz
STORY_PUBLIC_S3_PUBLIC_URL=https://cdn.onfood.uz/onfood-images
STORY_PUBLIC_S3_ACCOUNT_ID=

# Shared only with adminpanel. Generate one value with: openssl rand -hex 32
STORY_MODERATION_INTERNAL_SECRET=REPLACE_WITH_SHARED_64_HEX_SECRET
STORY_MEDIA_MAX_RAW_SIZE_BYTES=104857600
STORY_MEDIA_MAX_DURATION=30s
STORY_MEDIA_FFMPEG_PATH=ffmpeg
STORY_MEDIA_FFPROBE_PATH=ffprobe
STORY_MEDIA_PROCESSOR_BATCH_SIZE=1
# Deprecated rollout alias, leave unset after switching to BATCH_SIZE:
# STORY_MEDIA_PROCESSOR_CONCURRENCY=1
STORY_MEDIA_TEMP_DIR=/tmp/onfood-media
STORY_MEDIA_PROCESSING_LEASE=15m
STORY_MEDIA_FINALIZE_TIMEOUT=10s
STORY_MEDIA_MAX_INPUT_WIDTH=4096
STORY_MEDIA_MAX_INPUT_HEIGHT=4096
STORY_MEDIA_MAX_INPUT_PIXELS=10000000
STORY_MEDIA_MAX_FRAME_RATE=60.1
STORY_MEDIA_FFMPEG_THREADS=2
STORY_MEDIA_COMMAND_TIMEOUT=5m
STORY_MEDIA_MAX_COMMAND_OUTPUT_BYTES=65536
STORY_PUBLICATION_BATCH_SIZE=5
STORY_PUBLICATION_LEASE=5m
STORY_PUBLICATION_FINALIZE_TIMEOUT=10s
STORY_MODERATION_BATCH_SIZE=10
STORY_CLEANUP_BATCH_SIZE=50

REVIEW_MEDIA_VIPS_PATH=vips
REVIEW_MEDIA_VIPSHEADER_PATH=vipsheader
REVIEW_MEDIA_CWEBP_PATH=cwebp
REVIEW_MEDIA_TEMP_DIR=/tmp/onfood-media
REVIEW_MEDIA_PROCESSOR_BATCH_SIZE=5
REVIEW_MEDIA_PROCESSING_LEASE=5m
REVIEW_MEDIA_FINALIZE_TIMEOUT=10s
REVIEW_MEDIA_MAX_SIDE=16384
REVIEW_MEDIA_MAX_PIXELS=64000000
REVIEW_MEDIA_MAX_INPUT_BYTES=10485760
REVIEW_MEDIA_MAX_OUTPUT_BYTES=268435456
REVIEW_MEDIA_MAX_COMMAND_OUTPUT_BYTES=65536
REVIEW_MEDIA_COMMAND_TIMEOUT=2m
REVIEW_MEDIA_CLEANUP_BATCH_SIZE=50
MEDIA_TEMP_MAX_AGE=1h
MEDIA_TEMP_CLEANUP_BATCH_SIZE=100

# Deprecated STORY_MEDIA_S3_* values never replace the private bucket.
# STORY_MEDIA_S3_ENDPOINT=
# STORY_MEDIA_S3_ACCESS_KEY=
# STORY_MEDIA_S3_SECRET_KEY=
# STORY_MEDIA_S3_BUCKET=

# Payments
MULTICARD_BASE_URL=
MULTICARD_APPLICATION_ID=
MULTICARD_SECRET=
MULTICARD_STORE_ID=
MULTICARD_CALLBACK_URL=https://eats.onfood.uz/api/v1/webhooks/multicard/callback
MULTICARD_PAYMENT_TTL=5m

# SMS
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_SENDER=4546
ESKIZ_CALLBACK_URL=https://eats.onfood.uz/api/v1/webhooks/eskiz/sms-status
ESKIZ_CALLBACK_SECRET=

# App/runtime
APP_TIMEZONE=Asia/Tashkent
REDIS_URL=redis://redis:6379/0
MOCK_PAYMENTS=false

# Push
PUSH_ENABLED=false
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=
FCM_SERVICE_ACCOUNT_FILE=

# Notifications and story moderation
SENTRY_DSN=
ERROR_TELEGRAM_IDS=
ERROR_BOT_TOKEN=
FEEDBACK_TELEGRAM_CHAT_IDS=
ADMIN_TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_IDS=
