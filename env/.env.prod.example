# Compose-level env for /opt/onfood-prod/.env.
# Real values live only on the production server.

POSTGRES_USER=onfood
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=onfood_prod

MINIO_ROOT_USER=onfood
MINIO_ROOT_PASSWORD=CHANGEME

# Bucket created by minio-setup; must match backend/admin R2_BUCKET.
R2_BUCKET=onfood-images
STORY_PRIVATE_S3_BUCKET=onfood-story-private
STORY_PUBLIC_S3_BUCKET=onfood-images
